@page "/"
@using BlazorResourceTimeline.Components
@using BlazorResourceTimeline.Models
@using BlazorResourceTimeline.Demo.Data
@inject IJSRuntime JS

<PageTitle>Resource Timeline</PageTitle>

<div class="demo-page">
    <header class="demo-header">
        <div class="demo-title">
            <h1>Resource Timeline</h1>
        </div>

        <div class="demo-controls">
            <label>
                Days
                <select @bind="_days" @bind:after="RegenerateAsync">
                    <option value="7">7</option>
                    <option value="30">30</option>
                    <option value="100">100</option>
                    <option value="365">365</option>
                </select>
            </label>
            <label class="bar-height-control">
                Bar height
                <input type="range" min="2" max="32" step="1"
                       @bind="_barHeight" @bind:event="oninput" @bind:after="ApplyBarHeightAsync" />
                <span class="bar-height-value">@_barHeight px</span>
            </label>
            <label class="editable-control">
                <input type="checkbox" @bind="_editable" @bind:after="ApplyOptions" />
                Editable
            </label>
            <label class="editable-control" title="Serve only the visible window on demand instead of loading all bars up front">
                <input type="checkbox" @bind="_windowed" @bind:after="ToggleWindowed" />
                On-demand loading
            </label>
            <label class="editable-control" title="Render the resource column with a custom HTML template">
                <input type="checkbox" @bind="_customColumn" />
                Custom column
            </label>
            <label title="Which technology paints the timeline; behavior is identical across renderers">
                Renderer
                <select @bind="_renderer" @bind:after="ApplyOptions">
                    <option value="canvas">Canvas</option>
                    <option value="svg">SVG</option>
                    <option value="html">HTML</option>
                </select>
            </label>
            <label>
                Time zone
                <select @bind="_timeZone" @bind:after="ApplyOptions">
                    <option value="">Local</option>
                    <option value="UTC">UTC (Zulu)</option>
                    <option value="America/New_York">New York</option>
                    <option value="Europe/London">London</option>
                    <option value="Europe/Berlin">Berlin</option>
                    <option value="Asia/Tokyo">Tokyo</option>
                </select>
            </label>
            <span class="zoom-controls">
                Zoom
                <button class="btn-zoom" @onclick="ZoomOutAsync" title="Zoom out">&minus;</button>
                <button class="btn-zoom" @onclick="ZoomInAsync" title="Zoom in">+</button>
                <button class="btn-zoom" @onclick="ResetZoomAsync" title="Reset zoom">Reset</button>
            </span>
            <button class="btn-today" @onclick="GoToTodayAsync">Go to Today</button>
            <button class="btn-regenerate" @onclick="RegenerateAsync">Regenerate</button>
            <button class="btn-code" @onclick="ToggleCode">
                @(_showCode ? "Hide Code" : "Show Code")
            </button>
        </div>
    </header>

    <section class="demo-stats">
        <span><strong>@LeafResourceCount</strong> resources</span>
        <span><strong>@(_config?.Allocations.Count ?? 0)</strong> allocations</span>
        <span><strong>@_days</strong> days</span>
        @if (_lastEdit is not null)
        {
            <span class="last-edit">Last edit: @_lastEdit</span>
        }
        @if (_selectedBars.Count > 1)
        {
            <span class="selection">
                <strong>@_selectedBars.Count</strong> bars selected
                (@FormatDuration(_selectedBars.Aggregate(TimeSpan.Zero, (acc, b) => acc + (b.EndTime - b.StartTime))) total)
            </span>
            <button class="btn-clear" @onclick="ClearSelectionAsync">Clear</button>
        }
        else if (_selectedBars.Count == 1)
        {
            <span class="selection">
                Selected: <strong>@ResourceNameFor(_selectedBars[0].ResourceId)</strong>
                @FormatTime(_selectedBars[0].StartTime) &ndash; @FormatTime(_selectedBars[0].EndTime)
                (@FormatDuration(_selectedBars[0].EndTime - _selectedBars[0].StartTime))
            </span>
            <button class="btn-clear" @onclick="ClearSelectionAsync">Clear</button>
        }
        else
        {
            <span class="selection muted">No bar selected &mdash; drag to marquee-select, Ctrl+click to multi-select</span>
        }
    </section>

    <div class="demo-timeline">
        @if (_config is not null)
        {
            <BlazorResourceTimeline @ref="_timeline"
                              @key="_customColumn"
                              Config="_config"
                              Options="_options"
                              LoadAllocationsAsync="@(_windowed ? LoadWindowAsync : null)"
                              ResourceTemplate="@(_customColumn ? ColumnTemplate : null)"
                              OnSelectionChanged="HandleSelectionChanged"
                              OnAllocationChanged="HandleAllocationChanged">
                <TopStartContent>
                    <div class="corner">
                        <span class="corner-title">Resources</span>
                        <span class="corner-sub">Hour</span>
                    </div>
                </TopStartContent>
            </BlazorResourceTimeline>
        }
        @if (_isGenerating || _config is null)
        {
            <div class="demo-loading" role="status" aria-live="polite">
                <span class="demo-loading-spinner"></span>
                <span>Generating timeline data&hellip;</span>
            </div>
        }
        @* Code sample is overlaid on top of the timeline rather than replacing
           it, so the canvas stays mounted and sized. Toggling is instant and the
           renderer never has to re-initialize or reload data. *@
        <div class="demo-code @(_showCode ? "is-visible" : null)" aria-hidden="@(!_showCode)">
            <div class="demo-code-header">
                <span>Sample usage</span>
                <button class="btn-copy" @onclick="CopyCodeAsync">
                    @(_codeCopied ? "Copied!" : "Copy")
                </button>
            </div>
            <pre><code>@CodeSample</code></pre>
        </div>
    </div>
</div>

@code {
    private BlazorResourceTimeline? _timeline;
    private BlazorResourceTimelineConfig? _config;
    private IReadOnlyList<BlazorResourceTimelineAllocation> _selectedBars = Array.Empty<BlazorResourceTimelineAllocation>();
    private int _days = 100;
    private int _barHeight = 4;
    private string _renderer = "canvas";
    private string _timeZone = "";
    private bool _editable;
    private bool _windowed;
    private bool _customColumn;
    private string? _lastEdit;

    // Custom resource-column template: a colored dot + bold name, and a "group"
    // badge on parent rows (the chevron is added by the component automatically).
    private RenderFragment<BlazorResourceTimelineRowContext> ColumnTemplate => row =>
        @<span class="res-cell">
            <span class="res-dot" style="background:@DotColor(row)"></span>
            <span class="res-name">@row.Resource.Name</span>
            @if (row.HasChildren)
            {
                <span class="res-badge">group</span>
            }
        </span>;

    private static string DotColor(BlazorResourceTimelineRowContext row) =>
        row.HasChildren ? "#adb5bd" : "#1971c2";
    // A new Options instance is assigned on change so the component re-applies
    // it (Options is compared by reference, like Config).
    private BlazorResourceTimelineOptions? _options;
    private bool _isGenerating;
    private bool _showCode;
    private bool _codeCopied;
    private CancellationTokenSource? _generationCts;

    private const string CodeSample = """
        @page "/timeline"
        @using BlazorResourceTimeline.Components
        @using BlazorResourceTimeline.Models

        <BlazorResourceTimeline Config="_config"
                                OnSelectionChanged="HandleSelectionChanged" />

        @code {
            // All render data is bundled into a single Config instance. Assign a
            // new instance to re-render the timeline.
            private readonly BlazorResourceTimelineConfig _config = new()
            {
                Resources = new()
                {
                    new BlazorResourceTimelineResource { Id = "r1", Name = "Server A" },
                    new BlazorResourceTimelineResource { Id = "r2", Name = "Server B" },
                    new BlazorResourceTimelineResource { Id = "r3", Name = "Database" },
                },
                StartDate = DateTimeOffset.UtcNow.AddHours(-12),
                EndDate = DateTimeOffset.UtcNow.AddHours(12),
                Allocations = new()
                {
                    new BlazorResourceTimelineAllocation
                    {
                        Id = "c1",
                        ResourceId = "r1",
                        StartTime = DateTimeOffset.UtcNow.AddHours(-6).ToUnixTimeMilliseconds(),
                        EndTime = DateTimeOffset.UtcNow.AddHours(-2).ToUnixTimeMilliseconds(),
                        Color = "#1971c2",
                        // Optional per-bar height in pixels (defaults to a thin bar).
                        Height = 12,
                        TextAbove = "Batch job",
                        // Custom icons can be anchored at the start, end, above or
                        // below the bar. Source is any image URL or data URI.
                        Icons = new List<BlazorResourceTimelineBarIcon>
                        {
                            new() { Source = "/icons/check.svg", Position = BlazorResourceTimelineBarIconPosition.Start },
                            new() { Source = "/icons/star.svg", Position = BlazorResourceTimelineBarIconPosition.End, Size = 18 },
                        },
                    },
                    new BlazorResourceTimelineAllocation
                    {
                        Id = "c2",
                        ResourceId = "r2",
                        StartTime = DateTimeOffset.UtcNow.AddHours(-1).ToUnixTimeMilliseconds(),
                        EndTime = DateTimeOffset.UtcNow.AddHours(3).ToUnixTimeMilliseconds(),
                        Color = "#e8590c",
                        TextStart = "08:30",
                        TextEnd = "12:30",
                        // Decorative edge bars extend before/after the main bar,
                        // e.g. to show a delay around the planned period.
                        StartBar = new BlazorResourceTimelineEdgeBar { Duration = 30 * 60 * 1000, Color = "red" },
                        EndBar = new BlazorResourceTimelineEdgeBar { Duration = 45 * 60 * 1000, Color = "red" },
                        Icons = new List<BlazorResourceTimelineBarIcon>
                        {
                            new() { Source = "/icons/warning.svg", Position = BlazorResourceTimelineBarIconPosition.Above },
                        },
                    },
                    new BlazorResourceTimelineAllocation
                    {
                        Id = "c3",
                        ResourceId = "r3",
                        StartTime = DateTimeOffset.UtcNow.AddHours(2).ToUnixTimeMilliseconds(),
                        EndTime = DateTimeOffset.UtcNow.AddHours(8).ToUnixTimeMilliseconds(),
                        Color = "#2f9e44",
                        TextBelow = "Maintenance",
                        Icons = new List<BlazorResourceTimelineBarIcon>
                        {
                            new() { Source = "/icons/lock.svg", Position = BlazorResourceTimelineBarIconPosition.Start, Size = 16 },
                        },
                    },
                },
            };

            private void HandleSelectionChanged(BlazorResourceTimelineAllocation[] selected)
            {
                // selected contains every currently selected bar (empty when none).
                foreach (var bar in selected)
                {
                    Console.WriteLine($"Selected {bar.Id} on {bar.ResourceId}");
                }
            }
        }
        """;

    protected override Task OnInitializedAsync()
    {
        _options = BuildOptions();
        return RegenerateAsync();
    }

    private async Task RegenerateAsync()
    {
        // A new request supersedes any in-flight generation: cancel it so the
        // running loop bails out and the latest selection wins immediately.
        _generationCts?.Cancel();
        _generationCts?.Dispose();
        var cts = new CancellationTokenSource();
        _generationCts = cts;
        var token = cts.Token;

        // Show the generating overlay and let it paint before the heavy work
        // starts. The existing timeline (if any) stays mounted underneath so the
        // overlay is continuous through generation and into the renderer's own
        // loading spinner once the new data is handed over.
        _selectedBars = Array.Empty<BlazorResourceTimelineAllocation>();
        _isGenerating = true;
        StateHasChanged();
        // Task.Yield flushes the render batch but doesn't reliably yield a browser
        // paint on WebAssembly; a 1 ms delay does, so the overlay shows first.
        await Task.Delay(1);

        try
        {
            var config = await DataGenerator.GenerateSampleDataAsync(_days, token);

            // Ignore a result that has been superseded by a newer request.
            if (token.IsCancellationRequested)
            {
                return;
            }

            _config = config;
            ApplyBarHeightToData();
        }
        catch (OperationCanceledException)
        {
            // Superseded mid-run; the newer request owns the UI state.
        }
        finally
        {
            if (_generationCts == cts)
            {
                _isGenerating = false;
                _generationCts.Dispose();
                _generationCts = null;
            }
        }
    }

    private async Task GoToTodayAsync()
    {
        if (_timeline is not null)
        {
            await _timeline.GoToTodayAsync();
        }
    }

    private async Task ZoomInAsync()
    {
        if (_timeline is not null)
        {
            await _timeline.ZoomInAsync();
        }
    }

    private async Task ZoomOutAsync()
    {
        if (_timeline is not null)
        {
            await _timeline.ZoomOutAsync();
        }
    }

    private async Task ResetZoomAsync()
    {
        if (_timeline is not null)
        {
            await _timeline.ResetZoomAsync();
        }
    }

    // Applies the current bar height to every allocation in the loaded data.
    // Heights are mutated in place, so a ReloadAsync is needed to push the
    // change to the renderer.
    private void ApplyBarHeightToData()
    {
        if (_config is null)
        {
            return;
        }

        foreach (var allocation in _config.Allocations)
        {
            allocation.Height = _barHeight;
        }
    }

    private async Task ApplyBarHeightAsync()
    {
        ApplyBarHeightToData();
        if (_timeline is not null)
        {
            await _timeline.ReloadAsync();
        }
    }

    // Assigns a fresh Options instance so the component picks up the change
    // (Options is compared by reference). Rebuilt from all current selections.
    private void ApplyOptions() => _options = BuildOptions();

    // Toggling on-demand loading changes which data path the component uses.
    // Assigning a new Config reference makes it reload (after the updated
    // LoadAllocationsAsync parameter has been applied).
    private void ToggleWindowed()
    {
        if (_config is not null)
        {
            _config = CloneConfig(_config);
        }
    }

    private static BlazorResourceTimelineConfig CloneConfig(BlazorResourceTimelineConfig c) => new()
    {
        Resources = c.Resources,
        StartDate = c.StartDate,
        EndDate = c.EndDate,
        Allocations = c.Allocations,
    };

    // Demo "backend" for on-demand loading: returns every allocation whose time
    // span overlaps the requested window. A real app would query a database or
    // service here instead of filtering an in-memory list.
    private Task<IReadOnlyList<BlazorResourceTimelineAllocation>> LoadWindowAsync(BlazorResourceTimelineWindow window)
    {
        IReadOnlyList<BlazorResourceTimelineAllocation> result = _config is null
            ? Array.Empty<BlazorResourceTimelineAllocation>()
            : _config.Allocations
                .Where(a => a.EndTime >= window.Start && a.StartTime <= window.End)
                .ToList();
        return Task.FromResult(result);
    }

    // An empty time-zone selection means "use the viewer's local zone" (null).
    private BlazorResourceTimelineOptions BuildOptions() => new()
    {
        TimeZone = string.IsNullOrEmpty(_timeZone) ? null : _timeZone,
        Editable = _editable,
        Renderer = _renderer switch
        {
            "svg" => BlazorResourceTimelineRendererType.Svg,
            "html" => BlazorResourceTimelineRendererType.Html,
            _ => BlazorResourceTimelineRendererType.Canvas,
        },
    };

    // The component has already applied the move/resize to this instance in
    // place; a real app would persist it here. We just surface it in the UI.
    private void HandleAllocationChanged(BlazorResourceTimelineAllocation allocation)
    {
        _lastEdit = $"{ResourceNameFor(allocation.ResourceId)} " +
            $"{FormatTime(allocation.StartTime)} \u2013 {FormatTime(allocation.EndTime)}";
        StateHasChanged();
    }

    private async Task ClearSelectionAsync()
    {
        if (_timeline is not null)
        {
            await _timeline.ClearSelectionAsync();
        }
    }

    private void HandleSelectionChanged(BlazorResourceTimelineAllocation[] bars) => _selectedBars = bars;

    private void ToggleCode()
    {
        _showCode = !_showCode;
        _codeCopied = false;
    }

    private async Task CopyCodeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", CodeSample);
            _codeCopied = true;
        }
        catch
        {
            // Clipboard access can be blocked (e.g. insecure context); ignore.
        }
    }

    private string ResourceNameFor(string resourceId) =>
        _config?.Resources.FirstOrDefault(r => r.Id == resourceId)?.Name ?? resourceId;

    // Leaf resources only (exclude the group/root rows that organize the tree).
    private int LeafResourceCount
    {
        get
        {
            if (_config is null) return 0;
            var parents = _config.Resources
                .Where(r => r.ParentId is not null)
                .Select(r => r.ParentId!)
                .ToHashSet();
            return _config.Resources.Count(r => !parents.Contains(r.Id));
        }
    }

    private static string FormatTime(DateTimeOffset time) =>
        time.LocalDateTime.ToString("MMM d, HH:mm");

    private static string FormatDuration(TimeSpan span) =>
        span.TotalHours >= 1
            ? $"{(int)span.TotalHours}h {span.Minutes}m"
            : $"{span.Minutes}m";
}
